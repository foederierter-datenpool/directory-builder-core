@prefix :    <https://civic-data.de/pipeline#> .
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# The engine's contract for a well-formed federation.ttl
# expressed as SHACL and enforced by ../validate.js

:federationShape a sh:NodeShape ;
    sh:targetNode :federation ;
    sh:property [
        sh:path :hasSource ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "needs at least one :hasSource"
    ] .

:sourceShape a sh:NodeShape ;
    sh:targetObjectsOf :hasSource ;
    sh:property [
        sh:path :format ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:message "needs exactly one :format"
    ] .

# A SourceField's mint-key flag, the pure-config slice of the identity
# contract. The companion rule — every clean-less source needs an :iriSource
# field — is filesystem-dependent (it hinges on clean.sparql's presence) and
# lives in validate.js, not here.
:sourceFieldShape a sh:NodeShape ;
    sh:targetClass :SourceField ;
    sh:property [
        sh:path :iriSource ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message ":iriSource must be a single boolean"
    ] .

